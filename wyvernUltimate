-------------------- BULBOT HOOK (Genel) --------------------
local function HookAllBulletModules()
    local containers = {
        game:GetService("ReplicatedStorage"),
        game:GetService("ServerStorage"),
        LocalPlayer:WaitForChild("Backpack"),
        LocalPlayer.PlayerScripts,
        game:GetService("StarterPlayer").StarterPlayerScripts,
    }
    
    for _, container in ipairs(containers) do
        if container then
            pcall(function()
                for _, obj in ipairs(container:GetDescendants()) do
                    if obj:IsA("ModuleScript") then
                        local name = obj.Name:lower()
                        if name:find("bullet") or name:find("shoot") or name:find("fire") or name:find("gun") or name:find("weapon") then
                            local success, module = pcall(function() return require(obj) end)
                            if success and type(module) == "table" and module.Fire then
                                local oldFire = module.Fire
                                module.Fire = function(self, ...)
                                    if Config.Enabled then
                                        local target = GetClosestTargetPart()
                                        if target then
                                            local origin = self.Origin or Camera.CFrame.Position
                                            self.Direction = (target.Position - origin).Unit
                                            
                                            if self.TargetData then
                                                self.TargetData.Target = target
                                                self.TargetData.Hit = target.Position
                                            end
                                        end
                                    end
                                    return oldFire(self, ...)
                                end
                                print("[SILENT AIM] Hooked:", obj:GetFullName())
                            end
                        end
                    end
                end
            end)
        end
    end
end
