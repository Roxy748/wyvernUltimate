local function HookAbsorbing()
    local success, module = pcall(function()
        return require(game:GetService("ReplicatedStorage").Models.NewA4.Absorbing)
    end)
    
    if success and type(module) == "table" then
        print("[SILENT AIM] Absorbing module bulundu! İçindeki fonksiyonlar taranıyor...")
        
        -- Modüldeki tüm fonksiyonları tara
        for key, value in pairs(module) do
            if type(value) == "function" then
                local oldFunc = value
                module[key] = function(self, ...)
                    if Config.Enabled then
                        local target, targetPos = GetClosestTarget()
                        if target then
                            -- Argümanları kontrol et ve hedefi değiştir
                            local args = {...}
                            -- Eğer ilk argüman bir Vector3 (pozisyon) ise
                            if #args > 0 then
                                if type(args[1]) == "userdata" and pcall(function() return args[1].X end) then
                                    args[1] = targetPos
                                end
                                if #args > 1 and type(args[2]) == "userdata" and pcall(function() return args[2].X end) then
                                    args[2] = targetPos
                                end
                            end
                            return oldFunc(self, unpack(args))
                        end
                    end
                    return oldFunc(self, ...)
                end
                print("[SILENT AIM] Hooklandı:", tostring(key))
            elseif type(value) == "table" then
                -- İç içe tabloları da tara (Fire, Shoot vb.)
                for subKey, subValue in pairs(value) do
                    if type(subValue) == "function" then
                        local oldSubFunc = subValue
                        value[subKey] = function(self, ...)
                            if Config.Enabled then
                                local target, targetPos = GetClosestTarget()
                                if target then
                                    local args = {...}
                                    if #args > 0 then
                                        if type(args[1]) == "userdata" and pcall(function() return args[1].X end) then
                                            args[1] = targetPos
                                        end
                                        if #args > 1 and type(args[2]) == "userdata" and pcall(function() return args[2].X end) then
                                            args[2] = targetPos
                                        end
                                    end
                                    return oldSubFunc(self, unpack(args))
                                end
                            end
                            return oldSubFunc(self, ...)
                        end
                        print("[SILENT AIM] Alt fonksiyon hooklandı:", tostring(key) .. "." .. tostring(subKey))
                    end
                end
            end
        end
        
        print("[SILENT AIM] Absorbing hook tamamlandı!")
    else
        print("[SILENT AIM] Absorbing module bulunamadı veya yüklenemedi. 5 saniye sonra tekrar denenecek...")
        spawn(function()
            wait(5)
            HookAbsorbing()
        end)
    end
end
